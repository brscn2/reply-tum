# mode
SCHATTEN_INTEGRATION_MODE=mock        # mock | live

# database
DATABASE_URL=postgresql+asyncpg://schatten:schatten@postgres:5432/schatten

# AWS
AWS_ACCESS_KEY_ID=your-key-here
AWS_SECRET_ACCESS_KEY=your-secret-here
AWS_REGION=eu-central-1
BEDROCK_REGION=eu-central-1
S3_BUCKET=schatten-demo

# Bedrock model IDs (override defaults in bedrock/config.py)
BEDROCK_CLAUDE_OPUS=anthropic.claude-opus-4-6-v1
BEDROCK_CLAUDE_SONNET=anthropic.claude-sonnet-4-6-v1
BEDROCK_NOVA_PRO=amazon.nova-pro-v1
BEDROCK_TITAN_EMBED=amazon.titan-embed-text-v2
BEDROCK_LLAMA=meta.llama-4-scout-v1

# event bus
EVENT_BUS_DRIVER=sqs                  # sqs | pg_notify
SQS_QUEUE_URL=https://sqs.eu-central-1.amazonaws.com/123456789/schatten-events

# telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_WEBHOOK_URL=https://your-ngrok.ngrok.app/api/telegram/webhook

# google
GOOGLE_OAUTH_CLIENT_ID=your-client-id-here
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret-here
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/google/callback

# TUM (demo uses mock, live mode would fill these)
TUM_USERNAME=your-tum-id
TUM_PASSWORD=your-tum-password

# cognee
COGNEE_API_KEY=your-cognee-key-here
